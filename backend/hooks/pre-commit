#!/bin/bash
#
# Pre-commit hook for Dwar Rater
# Runs backend tests inside Docker container.
# Warns on failure but does NOT block commits (tests have known DB isolation issues).
#
# Install: cp backend/hooks/pre-commit .git/hooks/pre-commit

echo "Running pre-commit tests (in Docker)..."

PROJECT_DIR="$(git rev-parse --show-toplevel)"

# Find backend container
BACKEND_CONTAINER=$(docker ps --format '{{.Names}}' | grep "dwar-rater-backend" | head -1)

if [ -z "$BACKEND_CONTAINER" ]; then
    echo "[SKIP] Backend container not running."
    echo "Start containers with: docker compose up -d"
    exit 0
fi

# Run tests inside the container
if docker exec "$BACKEND_CONTAINER" python -m pytest -q --tb=line 2>&1; then
    echo ""
    echo "All tests passed."
    exit 0
else
    echo ""
    echo "========================================="
    echo "WARNING: Some tests failed."
    echo "Commit is allowed, but please fix tests."
    echo "Known issue: test DB isolation with PostgreSQL."
    echo "========================================="
    # Exit 0 to allow commit despite test failures
    exit 0
fi
