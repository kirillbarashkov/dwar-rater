# ========================================
# Dwar Rater — Environment Configuration
# ========================================

# PostgreSQL
POSTGRES_USER=dwar
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=dwar_rater
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Backend
DATABASE_URL=postgresql://dwar:change-me-in-production@postgres:5432/dwar_rater
AUTH_ENABLED=true
ADMIN_USER=admin
ADMIN_PASS=change-me-in-production
SECRET_KEY=change-me-in-production
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# CORS
CORS_ORIGINS=http://localhost:5173

# ========================================
# Safety — DO NOT CHANGE WITHOUT CAUTION
# ========================================

# When false (default), prevents docker compose down -v
# from destroying PostgreSQL data volume.
# Set to true ONLY when you have a verified backup.
ALLOW_VOLUME_DESTRUCTION=false
