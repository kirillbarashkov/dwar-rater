# Backend
SECRET_KEY=change-me-in-production
# DATABASE_URL is set automatically - do not override to ensure consistent database location
# For Docker, it uses sqlite:////app/instance/dwar_rater.db (via docker-compose)
# For local, it uses sqlite:///instance/dwar_rater.db (relative to backend/)
AUTH_ENABLED=true
ADMIN_USER=admin
ADMIN_PASS=change-me-in-production
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=60
APP_HTTP_PORT=5000

# Frontend
VITE_API_URL=http://localhost:5000

# PostgreSQL (for production)
POSTGRES_DB=dwar_rater
POSTGRES_USER=dwar
POSTGRES_PASSWORD=change-me-in-production

# Backup settings
BACKUP_KEEP_DAYS=7
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
ALLOW_VOLUME_DESTRUCTION=false
